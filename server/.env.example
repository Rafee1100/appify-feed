NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=appify_feed

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TTL=15m
REFRESH_TTL=7d

# Cloudinary — required for image uploads.
# Sign up free at https://cloudinary.com/ and copy values from the Console dashboard.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

UPLOAD_MAX_MB=5